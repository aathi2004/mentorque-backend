# Database (Supabase or NeonDB Postgres connection string)
DATABASE_URL=your_database_connection_string

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=30d

# Server
PORT=5001
NODE_ENV=development

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:5173

# Admin seed credentials (used by src/scripts/seed.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User

# Optional: free Hugging Face Inference API token for real sentence embeddings
# in the mentor-recommendation matcher. If unset, a local hashing-based
# embedding fallback is used automatically - no external calls required.
HF_API_TOKEN=
